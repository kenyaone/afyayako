# Environment / secrets — never commit these
.env
.env.*
!.env.example

# Node
node_modules/

# Frontend build output — regenerated by `npm run build` in frontend/
frontend/dist/
frontend/build-attempt.log

# Backup / scratch files (kept for local reference only)
*.bak
*.tsx.bak

# Legacy separate frontend folder (superseded by frontend/ inside this repo)
afyayako-frontend/

# Backup folders auto-created by deploy scripts
_backup_*/

# Local Herd-generated files
api/database/database.sqlite
api/storage/logs/*.log
api/storage/framework/cache/data/*
api/storage/framework/sessions/*
api/storage/framework/views/*
!.gitkeep
