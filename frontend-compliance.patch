+function normalizePhone(input: string): string {
+  let d = input.replace(/\D/g, '')
+  if (d.startsWith('0')) d = '254' + d.slice(1)
+  else if ((d.startsWith('7') || d.startsWith('1')) && d.length === 9) d = '254' + d
+  return d
