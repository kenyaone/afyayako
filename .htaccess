Options -MultiViews -Indexes
DirectoryIndex index.html
RewriteEngine On

# Block sensitive files
<FilesMatch "(?i)(^\.env|\.(env|sql|patch|log|sh|bak|ini|conf|lock|sqlite|sqlite3)$)">
    Deny from all
</FilesMatch>

# Allow specific PHP files
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(admin-applications|exec-|apply-api)\.php$ - [L]

# Block other root PHP files
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^[^/]+\.php$ - [F,L]

# Route specific paths
RewriteRule ^verify-professionals/?$ admin-applications.php [L,QSA]
RewriteRule ^apply/?$ apply.html [L]

# Route API to Laravel
RewriteCond %{REQUEST_URI} ^/api/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/(.*)$ api/public/index.php/$1 [L,QSA]

# Default to index.html for everything else
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
